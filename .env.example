# S3 / MinIO
S3_ENDPOINT=https://example-s3-endpoint.com
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=minioadmin
S3_BUCKET=imagens

# Admin panel auth (Auth.js Credentials provider — no external identity provider needed)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_TRUST_HOST=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
